{
  "common_params": {
    "registration_method": "NDT_OMP",
    "score_threshold": 6.0,
    "ndt_resolution": 1.0,
    "ndt_step_size": 0.1,
    "ndt_num_threads": 8,
    "ndt_max_iterations": 25,
    "transform_epsilon": 0.01,
    "voxel_leaf_size": 1.5,
    "enable_scan_voxel_filter": true,
    "scan_min_range": 1.0,
    "scan_max_range": 80.0,
    "cloud_queue_depth": 1,
    "min_scan_interval_sec": 0.0,
    "predict_pose_from_previous_delta": true,
    "reject_above_score_threshold": true,
    "use_imu": false,
    "use_imu_preintegration": false,
    "use_odom": false,
    "enable_debug": false,
    "use_twist_prediction": true,
    "twist_prediction_use_angular_velocity": false,
    "max_twist_prediction_dt": 0.2,
    "enable_local_map_crop": true,
    "local_map_radius": 300.0,
    "local_map_min_points": 100,
    "enable_borderline_seed_rejection_gate": true,
    "borderline_seed_gate_score_threshold": 5.25,
    "borderline_seed_gate_min_seed_translation_m": 1.0
  },
  "runs": [
    {
      "name": "preset_baseline"
    },
    {
      "name": "max_dt01",
      "params": {
        "max_twist_prediction_dt": 0.1
      }
    },
    {
      "name": "post_reject_r5_thr55",
      "params": {
        "enable_post_reject_strict_score_threshold": true,
        "post_reject_strict_min_rejections": 5,
        "post_reject_strict_score_threshold": 5.5
      }
    },
    {
      "name": "rejected_seed_r3_fit6_t2_yaw5",
      "params": {
        "enable_rejected_seed_update": true,
        "rejected_seed_update_min_rejections": 3,
        "rejected_seed_update_max_fitness": 6.0,
        "rejected_seed_update_max_correction_translation_m": 2.0,
        "rejected_seed_update_max_correction_yaw_deg": 5.0
      }
    },
    {
      "name": "recovery_r3_gap1_seed10",
      "params": {
        "enable_recovery_retry_from_last_pose": true,
        "recovery_retry_from_last_pose_min_rejections": 3,
        "recovery_retry_from_last_pose_max_accepted_gap_sec": 1.0,
        "recovery_retry_from_last_pose_max_seed_translation_m": 10.0
      }
    },
    {
      "name": "post_reject_r5_plus_rejected_seed",
      "params": {
        "enable_post_reject_strict_score_threshold": true,
        "post_reject_strict_min_rejections": 5,
        "post_reject_strict_score_threshold": 5.5,
        "enable_rejected_seed_update": true,
        "rejected_seed_update_min_rejections": 3,
        "rejected_seed_update_max_fitness": 6.0,
        "rejected_seed_update_max_correction_translation_m": 2.0,
        "rejected_seed_update_max_correction_yaw_deg": 5.0,
        "max_twist_prediction_dt": 0.1
      }
    },
    {
      "name": "delta_only_no_twist",
      "params": {
        "use_twist_prediction": false
      }
    }
  ]
}
